        "dangerous": true,
        "description": "Reboot the system",
        "enabled": true,
        "icon": "cached",
        "name": "Reboot"
      },
      {
        "command": [
          "loginctl",
          "terminate-user",
          ""
        ],
        "dangerous": true,
        "description": "Log out of the current session",
        "enabled": true,
        "icon": "exit_to_app",
        "name": "Logout"
      },
      {
        "command": [
          "loginctl",
          "lock-session"
